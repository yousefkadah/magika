{
    "name": "yousefkadah/laravel-magika",
    "description": "Laravel package for AI-powered file type validation using Google's Magika model",
    "keywords": ["laravel", "magika", "file-type", "validation", "ai", "mime-type", "file-detection"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/validation": "^10.0|^11.0|^12.0|^13.0",
        "symfony/process": "^6.0|^7.0|^8.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "YousefKadah\\LaravelMagika\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YousefKadah\\LaravelMagika\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YousefKadah\\LaravelMagika\\MagikaServiceProvider"
            ],
            "aliases": {
                "Magika": "YousefKadah\\LaravelMagika\\Facades\\Magika"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
